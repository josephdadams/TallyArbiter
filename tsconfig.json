{
	"compilerOptions": {
		"lib": ["ES2019"],
		"target": "es6",
		"module": "CommonJS",
		"moduleResolution": "node10",
		"outDir": "./dist",
		"resolveJsonModule": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"downlevelIteration": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true
	},
	"exclude": ["./UI/"]
}
